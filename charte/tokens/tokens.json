{
  "$description": "Pirabel Labs — tokens de design (format W3C Design Tokens). Le pivot reste tokens.css ; ce JSON sert à l'interopérabilité (Style Dictionary, Figma, etc.).",
  "couleur": {
    "fond": {
      "base":      { "$type": "color", "$value": "#0E0E0E", "$description": "fond principal de page" },
      "alt":       { "$type": "color", "$value": "#161616", "$description": "sections alternées" },
      "surface":   { "$type": "color", "$value": "#1A1A1A", "$description": "cartes, panneaux" },
      "surface-2": { "$type": "color", "$value": "#202020", "$description": "survol / champs" }
    },
    "texte": {
      "principal":  { "$type": "color", "$value": "#E5E2E1", "$description": "texte courant" },
      "lumineux":   { "$type": "color", "$value": "#F5F4F1", "$description": "titres hero" },
      "attenue":    { "$type": "color", "$value": "rgba(229,226,225,0.62)" },
      "discret":    { "$type": "color", "$value": "rgba(229,226,225,0.40)" },
      "sur-accent": { "$type": "color", "$value": "#0E0E0E", "$description": "texte sur orange (accessible)" }
    },
    "accent": {
      "base":  { "$type": "color", "$value": "#FF5500", "$description": "orange signature Pirabel" },
      "clair": { "$type": "color", "$value": "#FF7A33", "$description": "survol, états" },
      "doux":  { "$type": "color", "$value": "rgba(255,85,0,0.12)", "$description": "fonds d'icônes, badges" }
    },
    "bordure": {
      "discrete": { "$type": "color", "$value": "rgba(229,226,225,0.08)" },
      "visible":  { "$type": "color", "$value": "rgba(229,226,225,0.15)" }
    },
    "semantique": {
      "succes": { "$type": "color", "$value": "#4ADE80" },
      "alerte": { "$type": "color", "$value": "#FBBF24" },
      "erreur": { "$type": "color", "$value": "#F87171" }
    }
  },
  "police": {
    "affichage": { "$type": "fontFamily", "$value": ["Montserrat", "system-ui", "sans-serif"] },
    "titre":     { "$type": "fontFamily", "$value": ["Space Grotesk", "system-ui", "sans-serif"] },
    "texte":     { "$type": "fontFamily", "$value": ["Inter", "system-ui", "sans-serif"] },
    "mono":      { "$type": "fontFamily", "$value": ["ui-monospace", "SFMono-Regular", "monospace"] }
  },
  "taille": {
    "display": { "$type": "dimension", "$value": "56px" },
    "h1":      { "$type": "dimension", "$value": "64px" },
    "h2":      { "$type": "dimension", "$value": "40px" },
    "h3":      { "$type": "dimension", "$value": "24px" },
    "h4":      { "$type": "dimension", "$value": "17.6px" },
    "body":    { "$type": "dimension", "$value": "16px" },
    "sm":      { "$type": "dimension", "$value": "14px" },
    "caption": { "$type": "dimension", "$value": "12px" }
  },
  "espace": {
    "1": { "$type": "dimension", "$value": "4px" },
    "2": { "$type": "dimension", "$value": "8px" },
    "3": { "$type": "dimension", "$value": "12px" },
    "4": { "$type": "dimension", "$value": "16px" },
    "5": { "$type": "dimension", "$value": "24px" },
    "6": { "$type": "dimension", "$value": "32px" },
    "7": { "$type": "dimension", "$value": "48px" },
    "8": { "$type": "dimension", "$value": "64px" }
  },
  "rayon": {
    "sm":   { "$type": "dimension", "$value": "8px" },
    "md":   { "$type": "dimension", "$value": "14px" },
    "lg":   { "$type": "dimension", "$value": "20px" },
    "full": { "$type": "dimension", "$value": "999px" }
  },
  "ombre": {
    "md": { "$type": "shadow", "$value": { "offsetX": "0", "offsetY": "8px", "blur": "24px", "spread": "0", "color": "rgba(0,0,0,0.40)" } }
  },
  "mouvement": {
    "transition": { "$type": "duration", "$value": "220ms" }
  }
}
