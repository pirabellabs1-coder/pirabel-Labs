{
  "version": 2,
  "functions": {
    "api/index.js": { "maxDuration": 30 }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com https://www.clarity.ms https://*.clarity.ms https://cdn.jsdelivr.net https://translate.google.com https://translate.googleapis.com https://www.gstatic.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://www.gstatic.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://www.google-analytics.com https://*.clarity.ms https://region1.google-analytics.com https://translate.googleapis.com https://translate.google.com; frame-src 'self' https://translate.google.com; frame-ancestors 'self'" },
        { "key": "Content-Language", "value": "fr" }
      ]
    },
    {
      "source": "/(.*)\\.(png|jpg|jpeg|gif|svg|webp|avif|ico|woff|woff2|ttf)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(css|js|img)/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/downloads/(.*)",
      "headers": [
        { "key": "Content-Disposition", "value": "attachment" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/charte(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/admin/(.*)", "destination": "/api" },
    { "source": "/devis/(.*)", "destination": "/api" },
    { "source": "/avis/(.*)", "destination": "/api" },
    { "source": "/pirabel-admin-7x9k2m", "destination": "/api" },
    { "source": "/blog", "destination": "/api" },
    { "source": "/blog/(.*)", "destination": "/api" },
    { "source": "/realisations", "destination": "/api" },
    { "source": "/realisations/(.*)", "destination": "/api" },
    { "source": "/temoignages", "destination": "/api" },
    { "source": "/sitemap.xml", "destination": "/api" }
  ],
  "redirects": [
    { "source": "/article-:slug", "destination": "/blog/:slug", "permanent": true },
    { "source": "/blog/webflow-vs-wordpress-comparatif-2026", "destination": "/blog/wordpress-vs-webflow-vs-nextjs-2026", "permanent": true },
    { "source": "/blog/tiktok-entreprises-guide-marketing", "destination": "/blog/tiktok-pme-roi-strategie-contenu", "permanent": true },
    { "source": "/blog/email-marketing-erreurs-taux-ouverture", "destination": "/blog/email-marketing-2026-rgpd-automation-pme", "permanent": true },
    { "source": "/blog/fiche-google-business-guide-pack-local", "destination": "/blog/google-business-profile-guide-complet", "permanent": true },
    { "source": "/creation-application", "destination": "/creation-application-web", "permanent": true },
    { "source": "/automatisation", "destination": "/automatisation-marketing", "permanent": true },
    { "source": "/formation/:slug*", "destination": "/contact", "permanent": false },
    { "source": "/lesson/:slug*", "destination": "/contact", "permanent": false },
    { "source": "/en/:slug*", "destination": "/", "permanent": false }
  ],
  "cleanUrls": true,
  "trailingSlash": false
}
