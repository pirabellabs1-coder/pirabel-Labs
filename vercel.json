{
  "version": 2,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.googletagmanager.com https://www.google-analytics.com https://cdn.tiny.cloud; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com; img-src 'self' data: https: blob:; connect-src 'self' https://www.google-analytics.com https://pirabellabs.com https://*.pirabellabs.com; frame-ancestors 'self'" }
      ]
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/dashboard", "dest": "/api/index.js" },
    { "src": "/clients", "dest": "/api/index.js" },
    { "src": "/projects", "dest": "/api/index.js" },
    { "src": "/orders", "dest": "/api/index.js" },
    { "src": "/employees", "dest": "/api/index.js" },
    { "src": "/invoices", "dest": "/api/index.js" },
    { "src": "/revenue", "dest": "/api/index.js" },
    { "src": "/settings", "dest": "/api/index.js" },
    { "src": "/campaigns", "dest": "/api/index.js" },
    { "src": "/messages", "dest": "/api/index.js" },
    { "src": "/articles", "dest": "/api/index.js" },
    { "src": "/analytics", "dest": "/api/index.js" },
    { "src": "/portal", "dest": "/api/index.js" },
    { "src": "/pirabel-admin-7x9k2m", "dest": "/api/index.js" },
    { "src": "/portal-login", "dest": "/api/index.js" },
    { "src": "/notes", "dest": "/api/index.js" },
    { "src": "/prospects", "dest": "/api/index.js" },
    { "handle": "filesystem" },
    { "src": "/services", "dest": "/services.html" },
    { "src": "/blog", "dest": "/blog.html" },
    { "src": "/contact", "dest": "/contact.html" },
    { "src": "/a-propos", "dest": "/a-propos.html" },
    { "src": "/faq", "dest": "/faq.html" },
    { "src": "/resultats", "dest": "/resultats.html" },
    { "src": "/mentions-legales", "dest": "/mentions-legales.html" },
    { "src": "/politique-confidentialite", "dest": "/politique-confidentialite.html" },
    { "src": "/blog-article", "dest": "/blog-article.html" },
    { "src": "/guides$", "dest": "/guides/index.html" },
    { "src": "/(agence-[^/]+)$", "dest": "/$1/index.html" },
    { "src": "/(agence-[^/]+)/([^/]+)$", "dest": "/$1/$2.html" },
    { "src": "/(guides)/([^/]+)$", "dest": "/$1/$2.html" },
    { "src": "/espace-client-4p8w1n", "dest": "/espace-client-4p8w1n/index.html" }
  ]
}
